# ============================================
# STRIPE CONFIGURATION
# ============================================

# Clés Stripe (récupérables sur https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_51xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51xxxxx

# Secret du webhook Stripe (récupérable sur https://dashboard.stripe.com/webhooks)
# IMPORTANT: Ce secret est différent entre l'environnement de test et de production
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ============================================
# MARKETPLACE CONFIGURATION
# ============================================

# Pourcentage de commission prélevé par la plateforme sur chaque vente
# Par défaut: 20 (qui correspond à 20%)
PLATFORM_FEE_PERCENTAGE=20

# ============================================
# FEATURED PRODUCTS PRICES (en centimes)
# ============================================

FEATURED_HOMEPAGE_7D=4900      # 49€ pour mise en avant homepage 7 jours
FEATURED_HOMEPAGE_30D=14900    # 149€ pour mise en avant homepage 30 jours
FEATURED_CATEGORY_7D=2900      # 29€ pour mise en avant catégorie 7 jours
FEATURED_CATEGORY_30D=8900     # 89€ pour mise en avant catégorie 30 jours

# ============================================
# PREMIUM SUBSCRIPTION PRICES (en centimes)
# ============================================

PREMIUM_MONTHLY_PRICE=999      # 9,99€ par mois
PREMIUM_YEARLY_PRICE=9900      # 99€ par an

# ============================================
# NOTES IMPORTANTES
# ============================================

# 1. N'utilisez JAMAIS vos clés de production en développement
# 2. Les clés de test commencent par sk_test_ et pk_test_
# 3. Les clés de production commencent par sk_live_ et pk_live_
# 4. Ne commitez JAMAIS ce fichier avec vos vraies clés
# 5. Utilisez un fichier .env.local pour le développement local
# 6. Le webhook secret est différent pour chaque endpoint de webhook

# ============================================
# POUR TESTER LOCALEMENT
# ============================================

# 1. Installez Stripe CLI: https://stripe.com/docs/stripe-cli
# 2. Connectez-vous: stripe login
# 3. Écoutez les webhooks: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# 4. Le CLI affichera le webhook secret à utiliser pour les tests locaux

# ============================================
# CARTES DE TEST STRIPE
# ============================================

# Paiement réussi:
#   - Numéro: 4242 4242 4242 4242
#   - Date: n'importe quelle date future
#   - CVC: n'importe quel 3 chiffres
#   - ZIP: n'importe quel code

# Paiement refusé (fonds insuffisants):
#   - Numéro: 4000 0000 0000 9995

# Nécessite 3D Secure:
#   - Numéro: 4000 0025 0000 3155

# Plus de cartes de test: https://stripe.com/docs/testing
